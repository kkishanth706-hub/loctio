import qrcode
from urllib.parse import urlencode

# Your Google Form link
base_form_url = https://forms.gle/xcw2UjjA9udAxbse9

# Location and radius
latitude = 10.9629
longitude = 79.3912
radius =2# meters

# Data to attach in link
params = {
    "location": f"{latitude},{longitude}",
    "radius": radius
}

# Final link
final_url = base_form_url + "?" + urlencode(params)

print("Google Form Link:")
print(final_url)

# Generate QR Code
img = qrcode.make(final_url)
img.save("google_form_qr.png")

print("QR Code saved as google_form_qr.png")
