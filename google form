from flask import Flask, request, redirect
import qrcode

app = Flask(__name__)
FORM_URL = "https://docs.google.com/forms/d/e/FORM_ID/viewform?entry.123456789="

@app.route('/')
def home():
    return '''
    <!DOCTYPE html>
    <html>
    <head>
        <title>Location Capture</title>
    </head>
    <body style="text-align:center; margin-top:50px;">
        <h2>Click the button to share your location</h2>
        <button onclick="getLocation()" style="padding:10px 20px; font-size:16px;">
            Get Location
        </button>

        <script>
        function getLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(sendLocation);
            } else {
                alert("Geolocation not supported");
            }
        }

        function sendLocation(position) {
            let lat = position.coords.latitude;
            let lon = position.coords.longitude;
            let loc = "https://www.google.com/maps?q=" + lat + "," + lon;

            window.location.href = "/submit?loc=" + encodeURIComponent(loc);
        }
        </script>
    </body>
    </html>
    '''

@app.route('/submit')
def submit():
    loc = request.args.get('loc')
    return redirect(FORM_URL + loc)

if __name__ == '__main__':
    # 🔗 Change this after hosting (important)
    url = "http://127.0.0.1:5000/"

    # 📱 Generate QR code
    img = qrcode.make(url)
    img.save("qr_code.png")

    print("Server running at:", url)
    print("QR code saved as qr_code.png")

    app.run(debug=True)
